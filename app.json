{
  "expo": {
    "name": "EcoLocatie",
    "slug": "ecolocatie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoEcoLocation.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ecolocatie",
    "splash": {
      "image": "./assets/SmallLogoEcoLocation.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Aplicatia are nevoie de locatia ta pentru a afisa pozitia pe harta.",
        "NSCameraUsageDescription": "Aplicatia are nevoie de camera pentru a fotografia plantele.",
        "NSPhotoLibraryUsageDescription": "Aplicatia are nevoie de acces la galerie pentru a selecta fotografii cu plante."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/LogoEcoLocation.png"
      },
      "softwareKeyboardLayoutMode": "adjustResize",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.tudorrrr.ecolocatie"
    },
    "web": {
      "favicon": "./assets/LogoEcoLocation.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-image-picker"
    ]
  }
}
